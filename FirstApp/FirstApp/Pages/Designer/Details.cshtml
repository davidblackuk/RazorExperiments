@page
@model FirstApp.Pages.Designer.DetailsModel

@{
    ViewData["Title"] = "Details";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-page="/Index">
                <i class="fa-solid fa-home"></i> Home
            </a>
        </li>
        <li class="breadcrumb-item">
            <a asp-page="/Designer/Index">
                <i class="fa-solid fa-list"></i> Designer
            </a>
        </li>

       

    </ol>
</nav>

<div class="card shadow">
    <div class="card-header">
        <div class="d-flex justify-content-between align-items-center">
            <h4 class="mb-0"><i class="fa-solid fa-list me-1"></i> Repository: @Model.Repository.Name</h4>
           
        </div>
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.Repository.Name)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.Repository.Name)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.Repository.Description)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.Repository.Description)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.Repository.CreatedBy)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.Repository.CreatedBy.UserName)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.Repository.CreatedAt)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.Repository.CreatedAt)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.Repository.UpdatedBy)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.Repository.UpdatedBy.UserName)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.Repository.UpdatedAt)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.Repository.UpdatedAt)
            </dd>
        </dl>
    </div>
</div>

<div class="mt-4 card shadow">
    <div class="card-header">
        <div class="d-flex justify-content-between">
            <h4 class="mb-0"><i class="fa-solid fa-cube me-1"></i> Object Types</h4>
            <a asp-page="/ObjectTypes/CreateObjectType" asp-route-repositoryId="@Model.Repository.Id" class="btn btn-primary btn-sm">
                <i class="fa-solid fa-plus"></i> New Object Type
            </a>
        </div>
    </div>
    <div class="card-body">
        @if (Model.Repository.ObjectTypes.Any())
        {
            <div class="list-group">
                @foreach (var objectType in Model.Repository.ObjectTypes)
                {
                    <div class="list-group-item list-group-item-action">
                        <div class="row align-items-center">
                            <div class="col" style="cursor: pointer;" onclick="window.location.href='@Url.Page("/ObjectTypes/ObjectTypeDetails", new { id = objectType.Id })'">
                                <div class="d-flex justify-content-between">
                                    <h5 class="mb-1">@objectType.Name</h5>
                                    <div class="d-flex align-items-center">
                                        <a asp-page="/ObjectTypes/EditObjectType" asp-route-id="@objectType.Id" class="mx-1">
                                            Edit
                                        </a>
                                        |
                                        <a asp-page="/ObjectTypes/DeleteObjectType" asp-route-id="@objectType.Id" class="mx-1">
                                            Delete
                                        </a>
                                    </div>
                                </div>
                                @if (!string.IsNullOrEmpty(objectType.Description))
                                {
                                    <p class="mb-1 text-muted">@objectType.Description</p>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="text-muted">No object types found.</p>
        }
    </div>
</div>
