@page
@model FirstApp.Pages.Repositories.DeleteModel

@{
    ViewData["Title"] = "Delete Repository";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-page="/Repositories/Index">
                <i class="fa-solid fa-list"></i> Repositories
            </a>
        </li>
    </ol>
</nav>

<div class="card shadow">
    <div class="card-header">
        <h4 class="mb-0">Delete: @Model.Repository.Name</h4>
    </div>
    <div class="card-body">
        <h5>Are you sure you want to delete this?</h5>
        <dl class="row">
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.Repository.Name)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.Repository.Name)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.Repository.Description)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.Repository.Description)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.Repository.CreatedBy)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.Repository.CreatedBy.UserName)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.Repository.CreatedAt)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.Repository.CreatedAt)
            </dd>
        </dl>
    </div>
    <div class="card-footer text-center">
        <form method="post" class="d-inline">
            <input type="hidden" asp-for="Repository.Id" />
            <input type="submit" value="Delete" class="btn btn-danger btn-sm" />
            <a asp-page="./Index" class="btn btn-secondary btn-sm">Cancel</a>
        </form>
    </div>
</div>
