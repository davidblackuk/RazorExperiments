@page
@model FirstApp.Pages.Repositories.CreateModel

@{
    ViewData["Title"] = "Create Repository";
}

<div class="card shadow">
    <div class="card-header">
        <h4 class="mb-0">Create Repository</h4>
    </div>
    <div class="card-body">
        <form method="post" id="repositoryForm">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Repository.CreatedById" />
            <input type="hidden" asp-for="Repository.CreatedAt" />
            <input type="hidden" asp-for="Repository.UpdatedById" />
            <input type="hidden" asp-for="Repository.UpdatedAt" />
            <div class="form-group mb-3">
                <label asp-for="Repository.Name" class="control-label"></label>
                <input asp-for="Repository.Name" class="form-control" />
                <span asp-validation-for="Repository.Name" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Repository.Description" class="control-label"></label>
                <textarea asp-for="Repository.Description" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Repository.Description" class="text-danger"></span>
            </div>
        </form>
    </div>
    <div class="card-footer text-center">
        <button type="submit" form="repositoryForm" class="btn btn-primary btn-sm">Create</button>
        <a asp-page="Index" class="btn btn-secondary btn-sm">Cancel</a>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
    
