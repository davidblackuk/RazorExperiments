@page
@model FirstApp.Pages.Repositories.DetailsModel

@{
    ViewData["Title"] = "Details";
}

<div class="card mt-5">
    <div class="card-header">
        <div class="d-flex justify-content-between align-items-center">
            <h4 class="mb-0">Repository: @Model.Repository.Name</h4>
            <a asp-page="./Edit" asp-route-id="@Model.Repository.Id" class="btn btn-primary btn-sm">Edit</a>
        </div>
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.Repository.Name)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.Repository.Name)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.Repository.Description)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.Repository.Description)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.Repository.CreatedBy)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.Repository.CreatedBy.UserName)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.Repository.CreatedAt)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.Repository.CreatedAt)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.Repository.UpdatedBy)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.Repository.UpdatedBy.UserName)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.Repository.UpdatedAt)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.Repository.UpdatedAt)
            </dd>
        </dl>
    </div>
</div>

<div class="mt-4 card">
    <div class="card-header">
        <div class="d-flex justify-content-between">
            <h4 class="mb-0">Object Types</h4>
            <a asp-page="/ObjectTypes/Create" asp-route-repositoryId="@Model.Repository.Id" class="btn btn-primary btn-sm">
                <i class="fa-solid fa-plus"></i> New Object Type
            </a>
        </div>
    </div>
    <div class="card-body">
        @if (Model.Repository.ObjectTypes.Any())
        {
            <table class="table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Description</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var objectType in Model.Repository.ObjectTypes)
                    {
                        <tr>
                            <td>@objectType.Name</td>
                            <td>@objectType.Description</td>
                            <td>
                                <a asp-page="/ObjectTypes/Details" asp-route-id="@objectType.Id">Details</a> |
                                <a asp-page="/ObjectTypes/Edit" asp-route-id="@objectType.Id">Edit</a> |
                                <a asp-page="/ObjectTypes/Delete" asp-route-id="@objectType.Id">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p>No object types found.</p>
        }
    </div>
</div>
