@page
@model FirstApp.Pages.PropertyTypes.DeleteModel

@{
    ViewData["Title"] = "Delete Property Type";
}

<div class="card mt-5">
    <div class="card-header">
        <h4 class="mb-0">Delete: @Model.PropertyType.Name</h4>
    </div>
    <div class="card-body">
        <h5>Are you sure you want to delete this?</h5>
        <dl class="row">
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.PropertyType.Name)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.PropertyType.Name)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.PropertyType.Description)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.PropertyType.Description)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.PropertyType.ObjectType)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.PropertyType.ObjectType.Name)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.PropertyType.CreatedBy)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.PropertyType.CreatedBy.UserName)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.PropertyType.CreatedAt)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.PropertyType.CreatedAt)
            </dd>
        </dl>
    </div>
    <div class="card-footer text-center">
        <form method="post" class="d-inline">
            <input type="hidden" asp-for="PropertyType.Id" />
            <input type="submit" value="Delete" class="btn btn-danger btn-sm" />
            <a asp-page="./Index" class="btn btn-secondary btn-sm">Cancel</a>
        </form>
    </div>
</div>
