@page
@model FirstApp.Pages.PropertyTypes.DeleteModel

@{
    ViewData["Title"] = "Delete Property Type";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-page="/Index">
                <i class="fa-solid fa-home"></i> Home
            </a>
        </li>
        <li class="breadcrumb-item">
            <a asp-page="/Designer/Index">
                <i class="fa-solid fa-list"></i> Repositories
            </a>
        </li>
        <li class="breadcrumb-item">
            <a asp-page="/Designer/Details" asp-route-id="@Model.PropertyType.ObjectType!.Repository!.Id">
                <i class="fa-solid fa-database"></i> @Model.PropertyType.ObjectType!.Repository!.Name
            </a>
        </li>
        <li class="breadcrumb-item">
            <a id="backToRepository" asp-page="/ObjectTypes/Details" , asp-route-id="@Model.PropertyType.ObjectType.Id" )">
                <i class="fa-solid fa-cube"></i> @Model.PropertyType.ObjectType.Name
            </a>
        </li>

    </ol>
</nav>

<div class="card shadow">
    <div class="card-header">
        <h4 class="mb-0"><i class="fa-solid fa-diagram-project me-1"></i> Delete: @Model.PropertyType.Name</h4>
    </div>
    <div class="card-body">
        <h5>Are you sure you want to delete <strong>@Model.PropertyType.Name</strong>?</h5>
        <dl class="row">
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.PropertyType.Name)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.PropertyType.Name)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.PropertyType.Description)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.PropertyType.Description)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.PropertyType.DataType)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.PropertyType.DataType)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.PropertyType.ObjectType)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.PropertyType.ObjectType!.Name)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.PropertyType.CreatedBy)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.PropertyType.CreatedBy!.UserName)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.PropertyType.CreatedAt)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.PropertyType.CreatedAt)
            </dd>
        </dl>
        <div class="alert alert-danger text-center">
            Deleting this property type will delete all data for <strong>@Model.PropertyType.Name</strong>, from all objects of type <strong>@Model.PropertyType.ObjectType.Name</strong> . There
            is no undo operation for this action.
        </div>

    </div>
    <div class="card-footer text-center">
        <form method="post" class="d-inline">
            <input type="hidden" asp-for="PropertyType.Id" />
            <input type="submit" value="Delete" class="btn btn-danger btn-sm" />
            <a asp-page="/ObjectTypes/Details" asp-route-id="@Model.PropertyType.ObjectTypeId" class="btn btn-secondary btn-sm">Cancel</a>
        </form>
    </div>
</div>
