@page
@model FirstApp.Pages.PropertyTypes.DeleteModel

@{
    ViewData["Title"] = "Delete Property Type";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-page="/Repositories/Details" asp-route-id="@Model.PropertyType.ObjectType.RepositoryId">
                <i class="fa-solid fa-database"></i> @Model.PropertyType.ObjectType.Repository.Name
            </a>
        </li>
        <li class="breadcrumb-item">
            <a asp-page="/ObjectTypes/Details" asp-route-id="@Model.PropertyType.ObjectTypeId">
                <i class="fa-solid fa-cube"></i> @Model.PropertyType.ObjectType.Name
            </a>
        </li>
    </ol>
</nav>

<div class="card shadow mt-5">
    <div class="card-header">
        <h4 class="mb-0">Delete: @Model.PropertyType.Name</h4>
    </div>
    <div class="card-body">
        <h5>Are you sure you want to delete this?</h5>
        <dl class="row">
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.PropertyType.Name)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.PropertyType.Name)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.PropertyType.Description)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.PropertyType.Description)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.PropertyType.DataType)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.PropertyType.DataType)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.PropertyType.ObjectType)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.PropertyType.ObjectType.Name)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.PropertyType.CreatedBy)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.PropertyType.CreatedBy.UserName)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.PropertyType.CreatedAt)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.PropertyType.CreatedAt)
            </dd>
        </dl>
    </div>
    <div class="card-footer text-center">
        <form method="post" class="d-inline">
            <input type="hidden" asp-for="PropertyType.Id" />
            <input type="submit" value="Delete" class="btn btn-danger btn-sm" />
            <a asp-page="/ObjectTypes/Details" asp-route-id="@Model.PropertyType.ObjectTypeId" class="btn btn-secondary btn-sm">Cancel</a>
        </form>
    </div>
</div>
