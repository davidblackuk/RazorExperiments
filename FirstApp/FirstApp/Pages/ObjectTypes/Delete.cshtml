@page
@model FirstApp.Pages.ObjectTypes.DeleteModel

@{
    ViewData["Title"] = "Delete Object Type";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-page="/Index">
                <i class="fa-solid fa-home"></i> Home
            </a>
        </li>
        <li class="breadcrumb-item">
            <a asp-page="/Repositories/Index">
                <i class="fa-solid fa-list"></i> Repositories
            </a>
        </li>
        <li class="breadcrumb-item">
            <a asp-page="/Repositories/Details" asp-route-id="@Model.ObjectType.RepositoryId">
                <i class="fa-solid fa-database"></i> @Model.ObjectType.Repository.Name
            </a>
        </li>
    </ol>
</nav>

<div class="card shadow">
    <div class="card-header">
        <h4 class="mb-0">Delete: @Model.ObjectType.Name</h4>
    </div>
    <div class="card-body">
        <h5>Are you sure you want to delete this?</h5>

        @if (Model.ObjectType.PropertyTypes != null && Model.ObjectType.PropertyTypes.Any())
        {
            <div class="alert alert-warning" role="alert">
                <strong>Warning:</strong> Deleting this object type will also delete @Model.ObjectType.PropertyTypes.Count associated property type(s).
            </div>
        }

        <dl class="row">
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.ObjectType.Name)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.ObjectType.Name)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.ObjectType.Description)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.ObjectType.Description)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.ObjectType.CreatedBy)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.ObjectType.CreatedBy.UserName)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.ObjectType.CreatedAt)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.ObjectType.CreatedAt)
            </dd>
            @if (Model.ObjectType.PropertyTypes != null && Model.ObjectType.PropertyTypes.Any())
            {
                <dt class="col-sm-2">
                    Property Types
                </dt>
                <dd class="col-sm-10">
                    <ul class="list-unstyled mb-0">
                        @foreach (var propertyType in Model.ObjectType.PropertyTypes)
                        {
                            <li>@propertyType.Name</li>
                        }
                    </ul>
                </dd>
            }
        </dl>
    </div>
    <div class="card-footer text-center">
        <form method="post" class="d-inline">
            <input type="hidden" asp-for="ObjectType.Id" />
            <input type="submit" value="Delete" class="btn btn-danger btn-sm" />
            <a asp-page="/Repositories/Details" asp-route-id="@Model.ObjectType.RepositoryId" class="btn btn-secondary btn-sm">Cancel</a>
        </form>
    </div>
</div>
