@page
@model FirstApp.Pages.ObjectTypes.DeleteModel

@{
    ViewData["Title"] = "Delete Object Type";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-page="/Index" , new id=" = Model.Repository.Id">
                <i class="fa-solid fa-home"></i> Home
            </a>
        </li>
        <li class="breadcrumb-item">
            <a asp-page="/Designer/Index">
                <i class="fa-solid fa-list"></i> Designer
            </a>
        </li>
     
        <li class="breadcrumb-item">
            <a asp-page="/Designer/Details" asp-route-id="@Model.ObjectType.Repository!.Id">
                <i class="fa-solid fa-database"></i> @Model.ObjectType.Repository!.Name
            </a>
        </li>
    </ol>
</nav>

<div class="card shadow">
    <div class="card-header">
        <h4 class="mb-0"><i class="fa-solid fa-cube me-1"></i> Delete: @Model.ObjectType.Name</h4>
    </div>
    <div class="card-body">
        <h5>Are you sure you want to delete the object type <strong>@Model.ObjectType.Name</strong>?</h5>

        <dl class="row">
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.ObjectType.Name)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.ObjectType.Name)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.ObjectType.Description)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.ObjectType.Description)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.ObjectType.CreatedBy)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.ObjectType.CreatedBy.UserName)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.ObjectType.CreatedAt)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.ObjectType.CreatedAt)
            </dd>
            @if (Model.ObjectType.PropertyTypes != null && Model.ObjectType.PropertyTypes.Any())
            {
                bool first = true;
                <div class="alert alert-danger mt-3">
                    <p class="">
                        Deleting this object type will delete all property types and instances of it. There
                        is no undo operation for this action.
                    </p>
                    <p>
                        Property Types:
                        @foreach (var propertyType in Model.ObjectType.PropertyTypes)
                        {
                            if (!first)
                            {
                                <text>, </text>
                            }
                            @propertyType.Name

                            first = false;
                        }
                    </p>
                </div>
            }
        </dl>
    </div>
    <div class="card-footer text-center">
        <form method="post" class="d-inline">
            <input type="hidden" asp-for="ObjectType.Id" />
            <input type="submit" value="Delete" class="btn btn-danger btn-sm" />
            <a asp-page="/Designer/Details" asp-route-id="@Model.ObjectType.RepositoryId" class="btn btn-secondary btn-sm">Cancel</a>
           
        
        </form>
    </div>
</div>
