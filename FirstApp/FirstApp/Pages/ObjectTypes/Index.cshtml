@page
@model FirstApp.Pages.ObjectTypes.IndexModel

@{
    ViewData["Title"] = "Object Types";
}

<h1>Object Types</h1>

<p>
    <a asp-page="Create" class="btn btn-primary">Create New</a>
</p>

<div class="card shadow">
    <div class="card-header">
        <h4 class="mb-0">All Object Types</h4>
    </div>
    <div class="card-body">
        <table class="table">
            <thead>
                <tr>
                    <th>
                        @Html.DisplayNameFor(model => model.ObjectType[0].Name)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.ObjectType[0].Description)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.ObjectType[0].Repository)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.ObjectType[0].CreatedBy)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.ObjectType[0].CreatedAt)
                    </th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
        @foreach (var item in Model.ObjectType) {
                <tr>
                    <td>
                        @Html.DisplayFor(modelItem => item.Name)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Description)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Repository.Name)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.CreatedBy.UserName)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.CreatedAt)
                    </td>
                    <td>
                        <a asp-page="./Edit" asp-route-id="@item.Id">Edit</a> |
                        <a asp-page="./Details" asp-route-id="@item.Id">Details</a> |
                        <a asp-page="./Delete" asp-route-id="@item.Id">Delete</a>
                    </td>
                </tr>
        }
            </tbody>
        </table>
    </div>
</div>
