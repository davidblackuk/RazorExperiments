@page
@model Wyrm.Areas.Explorer.Pages.DeleteInstanceModel

@{
    ViewData["Title"] = "Delete Instance";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-area="" asp-page="/Index">
                <i class="fa-solid fa-home"></i> Home
            </a>
        </li>
        <li class="breadcrumb-item">
            <a asp-area="Explorer" asp-page="/Index">
                <i class="fa-solid fa-compass"></i> Explorer
            </a>
        </li>
        <li class="breadcrumb-item">
            <a asp-area="Explorer" asp-page="./ObjectTypes" asp-route-repositoryId="@Model.ObjectInstance.ObjectType!.Repository!.Id">
                <i class="fa-solid fa-database"></i> @Model.ObjectInstance.ObjectType!.Repository!.Name
            </a>
        </li>
        <li class="breadcrumb-item">
            <a asp-area="Explorer" asp-page="./Instances" asp-route-objectTypeId="@Model.ObjectInstance.ObjectType!.Id">
                <i class="fa-solid fa-cube"></i> @Model.ObjectInstance.ObjectType!.Name
            </a>
        </li>
        <li class="breadcrumb-item active" aria-current="page">
            <i class="fa-solid fa-clone"></i> Delete @Model.DisplayName
        </li>
    </ol>
</nav>

<div class="card shadow">
    <div class="card-header">
        <h4 class="mb-0"><i class="fa-solid fa-clone me-1"></i> Delete: @Model.DisplayName</h4>
    </div>
    <div class="card-body">
        <h5>Are you sure you want to delete <strong>@Model.DisplayName</strong>?</h5>

        <dl class="row">
            <dt class="col-sm-2">Created By</dt>
            <dd class="col-sm-10">@Model.ObjectInstance.CreatedBy?.UserName</dd>
            <dt class="col-sm-2">Created At</dt>
            <dd class="col-sm-10">@Model.ObjectInstance.CreatedAt</dd>
        </dl>

        <div class="alert alert-danger mt-3">
            <p class="mb-0">Deleting this instance will delete all of its property values. There is no undo operation for this action.</p>
        </div>
    </div>
    <div class="card-footer text-center">
        <form method="post" class="d-inline">
            <input type="hidden" asp-for="ObjectInstance.Id" />
            <input type="submit" value="Delete" class="btn btn-danger btn-sm" />
            <a asp-area="Explorer" asp-page="./Instances" asp-route-objectTypeId="@Model.ObjectInstance.ObjectType!.Id" class="btn btn-secondary btn-sm">Cancel</a>
        </form>
    </div>
</div>
