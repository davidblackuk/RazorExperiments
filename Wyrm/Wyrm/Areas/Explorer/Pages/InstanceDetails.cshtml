@page
@model Wyrm.Areas.Explorer.Pages.InstanceDetailsModel

@{
    ViewData["Title"] = "Instance Details";
    var objectType = Model.ObjectInstance.ObjectType!;
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-area="" asp-page="/Index">
                <i class="fa-solid fa-home"></i> Home
            </a>
        </li>
        <li class="breadcrumb-item">
            <a asp-area="Explorer" asp-page="/Index">
                <i class="fa-solid fa-compass"></i> Explorer
            </a>
        </li>
        <li class="breadcrumb-item">
            <a asp-area="Explorer" asp-page="./ObjectTypes" asp-route-repositoryId="@objectType.Repository!.Id">
                <i class="fa-solid fa-database"></i> @objectType.Repository!.Name
            </a>
        </li>
        <li class="breadcrumb-item">
            <a asp-area="Explorer" asp-page="./Instances" asp-route-objectTypeId="@objectType.Id">
                <i class="fa-solid fa-cube"></i> @objectType.Name
            </a>
        </li>
        <li class="breadcrumb-item active" aria-current="page">
            <i class="fa-solid fa-clone"></i> @Model.DisplayName
        </li>
    </ol>
</nav>

<div class="card shadow">
    <div class="card-header">
        <div class="d-flex justify-content-between align-items-center">
            <h4 class="mb-0"><i class="fa-solid fa-clone me-1"></i> @Model.DisplayName</h4>
            <div>
                <a asp-area="Explorer" asp-page="./EditInstance" asp-route-id="@Model.ObjectInstance.Id" class="btn btn-primary btn-sm">Edit</a>
                <a asp-area="Explorer" asp-page="./DeleteInstance" asp-route-id="@Model.ObjectInstance.Id" class="btn btn-danger btn-sm">Delete</a>
            </div>
        </div>
    </div>
    <div class="card-body">
        <dl class="row">
            @foreach (var propertyType in objectType.PropertyTypes)
            {
                var value = Model.Values.GetValueOrDefault(propertyType.Id);
                <dt class="col-sm-2">@propertyType.Name</dt>
                <dd class="col-sm-10">
                    @if (string.IsNullOrEmpty(value))
                    {
                        <span class="text-muted">(not set)</span>
                    }
                    else if (propertyType.DataType == PropertyDataType.Memo)
                    {
                        <span style="white-space: pre-wrap;">@value</span>
                    }
                    else
                    {
                        @value
                    }
                </dd>
            }
        </dl>
    </div>
    <div class="card-footer">
        <dl class="row mb-0">
            <dt class="col-sm-2">Created By</dt>
            <dd class="col-sm-4">@Model.ObjectInstance.CreatedBy?.UserName</dd>
            <dt class="col-sm-2">Created At</dt>
            <dd class="col-sm-4">@Model.ObjectInstance.CreatedAt</dd>
            <dt class="col-sm-2">Updated By</dt>
            <dd class="col-sm-4">@Model.ObjectInstance.UpdatedBy?.UserName</dd>
            <dt class="col-sm-2">Updated At</dt>
            <dd class="col-sm-4">@Model.ObjectInstance.UpdatedAt</dd>
        </dl>
    </div>
</div>
